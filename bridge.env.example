# Copy this file to `bridge.env` and fill in the values.
# bridge.env is gitignored — it holds secrets, never commit it.
#
# Lock it down on disk:
#   Linux/WSL : chmod 600 bridge.env
#   macOS     : chmod 600 bridge.env
#   Windows   : icacls bridge.env /inheritance:r /grant:r "%USERNAME%:R" "SYSTEM:R"

# --- required ---------------------------------------------------------------

# From @BotFather after /newbot
TELEGRAM_BOT_TOKEN=123456789:AA...your-bot-token...

# YOUR numeric Telegram user id (NOT a phone number). The bot only ever
# answers this id. Get it by messaging @userinfobot, or read it from the
# bridge log after sending the bot any message.
OWNER_ID=000000000

# --- claude -----------------------------------------------------------------

# Path to the Claude Code CLI binary.
#   Windows : C:\Users\<you>\.local\bin\claude.exe
#   macOS   : /Users/<you>/.local/bin/claude   (or `which claude`)
#   Linux   : /home/<you>/.local/bin/claude    (or `which claude`)
# On macOS launchd, set this to the ABSOLUTE path — a LaunchAgent does not
# inherit your shell PATH, so a bare `claude` will not be found.
CLAUDE_BIN=claude

# opus | sonnet | haiku  (changeable at runtime with /model)
CLAUDE_MODEL=opus

# Reasoning effort passed to claude as --effort (changeable with /effort).
# low | medium | high | xhigh | max  (default high)
CLAUDE_EFFORT=high

# Fast model used by /btw one-shot lookups (separate ephemeral session).
QUICK_MODEL=sonnet

# Default working directory the agent starts in. /ls lists its subfolders,
# /cd <name> hops into one.
DEFAULT_CWD=C:\Coding

# --- optional ---------------------------------------------------------------

# Where per-project session ids / offset / model are persisted.
STATE_PATH=state.json

# Hard ceiling (seconds) for a single agent turn before it is killed.
CLAUDE_TIMEOUT=1800

# Only needed if `claude` is NOT already logged in on this machine
# (on a logged-in desktop, leave this empty — it uses ~/.claude credentials).
# CLAUDE_CODE_OAUTH_TOKEN=

# --- voice / audio transcription (optional) ---------------------------------
# Voice messages, audio files and round video notes are transcribed to text,
# then sent to the agent as a normal prompt. Two backends, tried in order:
# STT_CMD (local) first, then STT_API_KEY (cloud). Neither set -> audio just
# gets a "not configured" notice.

# 1) LOCAL (recommended) — runs fully offline, no key, no audio leaves the PC.
#    The audio path is appended as the last argument; transcript read from
#    stdout. Ships with a faster-whisper helper (pip install faster-whisper):
STT_CMD=C:\Python313\python.exe C:\Coding\telegram-bridge\stt_faster_whisper.py
#    macOS / Linux equivalent (no spaces in paths):
#    STT_CMD=/usr/bin/python3 /Users/you/claude-telegram-bridge/stt_faster_whisper.py
#    Helper tunables (optional, forwarded to the helper from here):
#    STT_WHISPER_MODEL (tiny|base|small|medium|large-v3, default base),
#    STT_WHISPER_DEVICE (cpu|cuda|auto, default cpu),
#    STT_WHISPER_COMPUTE (default int8), STT_WHISPER_LANG (e.g. pt).
# STT_WHISPER_MODEL=small
# STT_WHISPER_LANG=pt
#    NOTE: paths here can't contain spaces (this parser strips wrapping quotes).

# 2) CLOUD fallback — OpenAI-compatible /audio/transcriptions. Used only when
#    STT_CMD is empty. Default = Groq (free tier, accepts OGG, no ffmpeg);
#    get a key at https://console.groq.com/keys
# STT_API_KEY=
# To use OpenAI instead: set the key above and uncomment:
# STT_API_URL=https://api.openai.com/v1/audio/transcriptions
# STT_MODEL=whisper-1
# Defaults (Groq) if left unset:
# STT_API_URL=https://api.groq.com/openai/v1/audio/transcriptions
# STT_MODEL=whisper-large-v3
