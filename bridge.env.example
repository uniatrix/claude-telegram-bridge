# Copy this file to `bridge.env` and fill in the values.
# bridge.env is gitignored — it holds secrets, never commit it.
#
# Lock it down on disk:
#   Linux/WSL : chmod 600 bridge.env
#   Windows   : icacls bridge.env /inheritance:r /grant:r "%USERNAME%:R" "SYSTEM:R"

# --- required ---------------------------------------------------------------

# From @BotFather after /newbot
TELEGRAM_BOT_TOKEN=123456789:AA...your-bot-token...

# YOUR numeric Telegram user id (NOT a phone number). The bot only ever
# answers this id. Get it by messaging @userinfobot, or read it from the
# bridge log after sending the bot any message.
OWNER_ID=000000000

# --- claude -----------------------------------------------------------------

# Path to the Claude Code CLI binary.
#   Windows : C:\Users\<you>\.local\bin\claude.exe
#   Linux   : /home/<you>/.local/bin/claude   (or `which claude`)
CLAUDE_BIN=claude

# opus | sonnet | haiku  (changeable at runtime with /model)
CLAUDE_MODEL=opus

# Default working directory the agent starts in. /ls lists its subfolders,
# /cd <name> hops into one.
DEFAULT_CWD=C:\Coding

# --- optional ---------------------------------------------------------------

# Where per-project session ids / offset / model are persisted.
STATE_PATH=state.json

# Hard ceiling (seconds) for a single agent turn before it is killed.
CLAUDE_TIMEOUT=1800

# Only needed if `claude` is NOT already logged in on this machine
# (on a logged-in desktop, leave this empty — it uses ~/.claude credentials).
# CLAUDE_CODE_OAUTH_TOKEN=
